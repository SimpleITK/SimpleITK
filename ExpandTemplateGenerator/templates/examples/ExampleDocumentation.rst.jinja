{#- Jinja2 template for generating a Documentation.rst stub for a filter example.
    Mirrors the structure of Examples/SimpleGaussian/Documentation.rst.
    Variables consumed from the filter YAML (same as the code example templates).
-#}
{%- if example is defined and example is not none -%}
  {%- set ex = example -%}
{%- elif tests is defined and tests -%}
  {%- set ex = tests[0] -%}
{%- else -%}
  {%- set ex = none -%}
{%- endif -%}
{%- set named_image_inputs = [] -%}
{%- if inputs -%}
  {%- for inp in inputs -%}
    {%- if inp.type == "Image" -%}
      {%- set _ = named_image_inputs.append(inp) -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
{%- set total_inputs = number_of_inputs + named_image_inputs | length -%}
{%- set has_output = not no_return_image -%}
{%- set procedure_name = name | regex_replace('ImageSource$', 'Source') | regex_replace('(ImageFilter|Filter)$', '') -%}
{%- set example_name = name -%}
{#- Build the call-args string for the exec_code block's run_example() invocation. -#}
{%- set ns = namespace(run_args="") -%}
{%- if ex and ex.inputs -%}
  {%- for img_path in ex.inputs -%}
    {%- if ns.run_args -%}{%- set ns.run_args = ns.run_args ~ ",\n            " -%}{%- endif -%}
    {%- set ns.run_args = ns.run_args ~ "data_path / '" ~ img_path ~ "'" -%}
  {%- endfor -%}
{%- else -%}
  {%- for i in range(total_inputs) -%}
    {%- if ns.run_args -%}{%- set ns.run_args = ns.run_args ~ ",\n            " -%}{%- endif -%}
    {%- set ns.run_args = ns.run_args ~ "'<input" ~ (i + 1 if total_inputs > 1 else "") ~ ">'" -%}
  {%- endfor -%}
{%- endif -%}
{%- if has_output -%}
  {%- if ns.run_args -%}{%- set ns.run_args = ns.run_args ~ ",\n            " -%}{%- endif -%}
  {%- set ns.run_args = ns.run_args ~ "'/tmp/" ~ example_name ~ "_output.nrrd'" -%}
{%- endif -%}
{%- set title_text = name | regex_replace('ImageSource$', 'Source') | regex_replace('(ImageFilter|Filter)$', '') -%}
{{ title_text }}
{{ "=" * (title_text | length) }}


