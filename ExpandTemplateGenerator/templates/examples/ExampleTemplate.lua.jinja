{#- Jinja2 template for generating Lua example scripts. -#}
{%- if example is defined and example is not none -%}
  {%- set ex = example -%}
{%- elif tests is defined and tests -%}
  {%- set ex = tests[0] -%}
{%- else -%}
  {%- set ex = none -%}
{%- endif -%}
{%- set named_image_inputs = [] -%}
{%- if inputs -%}
  {%- for inp in inputs -%}
    {%- if inp.type == "Image" and not inp.optional -%}
      {%- set _ = named_image_inputs.append(inp) -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
{%- set total_inputs = number_of_inputs + named_image_inputs | length -%}
{%- set has_output = not no_return_image -%}
{%- set procedure_name = name | regex_replace('ImageSource$', 'Source') | regex_replace('(ImageFilter|Filter)$', '') -%}
{%- set ns = namespace(exec_args="") -%}
{%- for i in range(1, number_of_inputs + 1) -%}
  {%- if ns.exec_args -%}{%- set ns.exec_args = ns.exec_args ~ ", " -%}{%- endif -%}
  {%- set ns.exec_args = ns.exec_args ~ "image" ~ (i if number_of_inputs > 1 else "") -%}
{%- endfor -%}
{%- for inp in named_image_inputs -%}
  {%- if ns.exec_args -%}{%- set ns.exec_args = ns.exec_args ~ ", " -%}{%- endif -%}
  {%- set ns.exec_args = ns.exec_args ~ (inp.name[0] | lower ~ inp.name[1:]) -%}
{%- endfor -%}

-- Example script for {{ name }}.
{% if briefdescription %}
-- {{ briefdescription | wordwrap(79) | replace('\n', '\n-- ') }}
{% endif %}
--
-- Usage:
--   lua {{ name }}.lua {% for i in range(1, number_of_inputs + 1) %}<input{{ i if number_of_inputs > 1 else "" }}> {% endfor %}{% for inp in named_image_inputs %}<{{ inp.name[0] | lower ~ inp.name[1:] }}> {% endfor %}{% if has_output %}<output>{% endif %}


require "SimpleITK"

local expected_args = {{ total_inputs + (1 if has_output else 0) }}
if #arg < expected_args then
  print("Usage: lua {{ name }}.lua"
{% for i in range(1, number_of_inputs + 1) %}
    .. " <input{{ i if number_of_inputs > 1 else "" }}>"
{% endfor %}
{% for inp in named_image_inputs %}
    .. " <{{ inp.name[0] | lower ~ inp.name[1:] }}>"
{% endfor %}
{% if has_output %}
    .. " <output>"
{% endif %}
  )
  os.exit(1)
end

local arg_idx = 1
local reader = SimpleITK.ImageFileReader()
local filter = SimpleITK.{{ name }}()

{% if number_of_inputs == 1 %}
-- Read the input image
reader:SetFileName(arg[arg_idx])
arg_idx = arg_idx + 1
local image = reader:Execute()
{% elif number_of_inputs >= 2 %}
-- Read the input images
{% for i in range(1, number_of_inputs + 1) %}
reader:SetFileName(arg[arg_idx])
arg_idx = arg_idx + 1
local image{{ i }} = reader:Execute()
{% endfor %}
{% endif %}
{% for inp in named_image_inputs %}
-- Read the {{ inp.name[0] | lower ~ inp.name[1:] }} image
reader:SetFileName(arg[arg_idx])
arg_idx = arg_idx + 1
local {{ inp.name[0] | lower ~ inp.name[1:] }} = reader:Execute()
{% endfor %}

-- Configure filter parameters
{% if ex and ex.settings %}
{% for setting in ex.settings %}
{% if setting.point_vec is defined and setting.point_vec %}
filter:Clear{{ setting.parameter | replace('List', 's') }}()
{% if setting.lua_value is defined and setting.lua_value %}
{% for pt in setting.lua_value %}
do
  local idx = SimpleITK.VectorUInt32()
  for _, v in ipairs({{ pt }}) do idx:push_back(v) end
  filter:Add{{ setting.parameter | replace('List', '') | regex_replace('s([0-9]?)$', '\\1') }}(idx)
end
{% endfor %}
{% else %}
{% for v in setting.value %}
do
  local idx = SimpleITK.VectorUInt32()
  for _, v in ipairs({{ v }}) do idx:push_back(v) end
  filter:Add{{ setting.parameter | replace('List', '') | regex_replace('s([0-9]?)$', '\\1') }}(idx)
end
{% endfor %}
{% endif %}
{% elif setting.dim_vec is defined and setting.dim_vec %}
do
  {% if setting.type is defined and setting.type == "bool" %}
  local v = SimpleITK.VectorBool()
  for _, x in ipairs({ {{ setting.value | join(", ") }} }) do v:push_back(x) end
  {% elif setting.type is defined and setting.type in ("unsigned int", "uint32_t") %}
  local v = SimpleITK.VectorUInt32()
  for _, x in ipairs({ {{ setting.value | join(", ") }} }) do v:push_back(x) end
  {% else %}
  local v = SimpleITK.VectorDouble()
  for _, x in ipairs({ {{ setting.value | join(", ") }} }) do v:push_back(x) end
  {% endif %}
  filter:Set{{ setting.parameter }}(v)
end
{% elif setting.type is defined and setting.type == "bool" %}
filter:Set{{ setting.parameter }}({{ "true" if setting.value else "false" }})
{% elif setting.lua_value is defined and setting.lua_value is not none %}
filter:Set{{ setting.parameter }}({{ setting.lua_value }})
{% else %}
filter:Set{{ setting.parameter }}({{ setting.value }})
{% endif %}
{% endfor %}
{% endif %}

{% if has_output %}
-- Execute the filter
local output = filter:Execute({{ ns.exec_args }})

-- Write the output image
local writer = SimpleITK.ImageFileWriter()
writer:SetFileName(arg[arg_idx])
writer:Execute(output)
{% else %}
-- Execute the filter
filter:Execute({{ ns.exec_args }})

{% if measurements %}
-- Print computed measurements
{%- set ns_p = namespace(has_param=false) %}
{%- for m in measurements %}{% if m.parameters is defined and m.parameters %}{% set ns_p.has_param = true %}{% endif %}{% endfor %}
{% for m in measurements %}
{%- if not (m.no_print is defined and m.no_print) and not (m.parameters is defined and m.parameters) %}
print("{{ m.name }}: " .. tostring(filter:Get{{ m.name }}()))
{%- endif %}
{% endfor %}
{%- if ns_p.has_param %}
-- Per-label measurements require a label argument:
for _, label in ipairs(filter:GetLabels()) do
  print("Label: " .. tostring(label))
{% for m in measurements %}
{%- if m.parameters is defined and m.parameters %}
  print("  {{ m.name }}: " .. tostring(filter:Get{{ m.name }}(label)))
{%- endif %}
{% endfor %}
end
{%- endif %}
{% endif %}
{% endif %}
